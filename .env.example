# ── Public site name (shown in metadata) ──────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=XMUM Physics Department Blog
# Full production site URL for canonical tags/sitemap (no trailing slash)
# Example: https://your-domain.com or https://username.github.io/repo-name
NEXT_PUBLIC_SITE_URL=https://example.com

# ── Admin publishing (dynamic deployment only) ───────────────────────────────
# Enable in-app admin panel and API routes
ENABLE_ADMIN=false
# Shared council password for /admin/login
ADMIN_PASSWORD=change-me
# Secret used to sign admin sessions (long random string)
ADMIN_SESSION_SECRET=change-this-long-random-secret

# ── Static export (GitHub Actions sets these automatically) ───────────────────
# Set STATIC_EXPORT=true to enable next export mode (output: 'export')
# STATIC_EXPORT=true
# BASE_PATH=/your-repo-name
