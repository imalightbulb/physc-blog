# ── Application secrets ────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Admin credentials (used to seed the admins table on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Public site name (shown in metadata)
NEXT_PUBLIC_SITE_NAME=XMUM Physics Department Blog

# ── Static export (GitHub Actions sets these automatically) ────────────────────
# Set STATIC_EXPORT=true to enable next export mode (output: 'export')
# STATIC_EXPORT=true
# BASE_PATH=/your-repo-name

# ── AI assistant API keys (for Continue.dev — NOT used by the Next.js app) ─────
# Add these to your shell profile (~/.zshrc or ~/.bashrc) or to a
# machine-local .env file (gitignored). Continue reads them as env vars.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
