# Firebase — create a project at https://console.firebase.google.com
# Then: Project Settings → Your apps → Web app → SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Social media profile URLs (optional — defaults are used if not set)
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/YOUR_HANDLE
NEXT_PUBLIC_XIAOHONGSHU_URL=https://www.xiaohongshu.com/user/profile/YOUR_ID
